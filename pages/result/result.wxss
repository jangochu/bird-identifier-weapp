.image-section {
  text-align: center;
  padding: 20rpx;
}

.result-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 12rpx;
}

.mock-notice {
  background-color: #fff7e6;
  border: 2rpx solid #ffc53d;
}

.mock-text {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #d48806;
  margin-bottom: 12rpx;
}

.mock-desc {
  display: block;
  font-size: 26rpx;
  color: #ad6800;
}

.description {
  background-color: #f6ffed;
  border: 2rpx solid #b7eb8f;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
  font-size: 28rpx;
  color: #389e0d;
  line-height: 1.6;
}

.result-section {
  margin-top: 24rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-item {
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 24rpx;
  position: relative;
}

.result-item.top-result {
  background-color: #e6f7ed;
  border: 2rpx solid #07c160;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.bird-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.confidence {
  font-size: 28rpx;
  color: #07c160;
  font-weight: bold;
}

.progress-bar {
  height: 12rpx;
  background-color: #e0e0e0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #10b981);
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.best-match {
  position: absolute;
  top: -10rpx;
  right: 20rpx;
  background-color: #07c160;
  color: white;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.no-result {
  text-align: center;
  padding: 60rpx;
  color: #999;
  font-size: 30rpx;
}

.actions {
  margin-top: 40rpx;
  padding: 0 20rpx;
}

.btn-full {
  width: 100%;
}