.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: #666;
}

.upload-card {
  min-height: 400rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 60rpx;
}

.upload-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.upload-text {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 16rpx;
}

.upload-hint {
  font-size: 24rpx;
  color: #999;
}

.preview-area {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.preview-image {
  width: 100%;
  max-height: 500rpx;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.preview-actions {
  display: flex;
  gap: 24rpx;
}

.btn-reselect {
  background-color: #f5f5f5;
  color: #666;
  border-radius: 8rpx;
  padding: 24rpx 48rpx;
  font-size: 28rpx;
  border: 1rpx solid #ddd;
}

.btn-reselect::after {
  border: none;
}

.error-tip {
  background-color: #ffe6e6;
  color: #ff4d4f;
  padding: 20rpx;
  border-radius: 8rpx;
  margin-top: 20rpx;
  text-align: center;
  font-size: 28rpx;
}

.tips {
  margin-top: 32rpx;
}

.tips-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.tips-item {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}